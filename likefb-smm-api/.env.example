PORT=4000
DATABASE_URL=postgresql://postgres.lradbeedbkzkxsrzkkwx:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
PASSWORD_PEPPER=optional_extra_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Telegram notify (optional)
# Create a bot and add it to your group/channel, then set chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: for forum topics
TELEGRAM_MESSAGE_THREAD_ID=

# Cleanup old refunded SMM_ERROR orders (optional)
# Deletes orders older than CLEANUP_REFUNDED_DAYS when they have been refunded and have SMM_ERROR.
CLEANUP_ENABLED=true
CLEANUP_REFUNDED_DAYS=30
CLEANUP_DELETE_LIMIT=500
# How often to run cleanup job (hours)
CLEANUP_INTERVAL_HOURS=24

# Upstream SMM provider (Perfect Panel style). URL must match panel docs, usually .../api/v2
SMM_API_URL=https://your-panel.example.com/api/v2
SMM_API_KEY=
# Optional: cookie header if provider requires it
# SMM_COOKIE=
# Default is form-urlencoded. Use json if panel requires it. Auto-retries once as JSON when panel returns "Request Not Found" unless you force form only:
# SMM_API_BODY_FORMAT=json
# SMM_API_BODY_FORMAT=form
# If panel docs use api_key instead of key:
# SMM_API_KEY_FIELD=api_key

