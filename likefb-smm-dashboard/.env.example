PORT=4000
#
# --- Vercel Production (quan trọng) ---
# Mọi request /api/* trên Vercel đi qua api/combined.ts (vercel.json rewrite).
#
# Cách A — Khuyến nghị: có host riêng chạy likefb-smm-api (Railway, Render, VPS…).
#   Trên Vercel (Project FRONTEND): chỉ cần
#   LIKEFB_SMM_API_BASE_URL=https://api-cua-ban.com   (không dấu / cuối)
#   Các biến SMM_API_URL, SMM_API_KEY… đặt trên SERVER API, không nhất thiết trên Vercel.
#
# Cách B — Chỉ deploy frontend lên Vercel, không có API Node: serverless gọi thẳng panel SMM.
#   Trên Vercel → Settings → Environment Variables (Production), thêm tối thiểu:
#   SMM_API_URL=https://smm.com.vn/api/v2   (POST tới path này; nếu chỉ ghi https://smm.com.vn code tự thêm /api/v2)
#   SMM_API_KEY=...
#   SMM_COOKIE=PHPSESSID=...   (thường bắt buộc; copy từ curl -H 'Cookie: ...')
#   Không dùng tiền tố VITE_ cho API key (VITE_ chỉ cho browser build).
#   Nếu panel trả "The Request Not Found" / "Invalid request": thử lần lượt
#   SMM_API_BODY_FORMAT=json
#   SMM_API_KEY_FIELD=api_key
#
# Vercel (serverless /api/combined): public HTTPS origin of likefb-smm-api, no trailing slash. Proxies orders, admin, free-like.
LIKEFB_SMM_API_BASE_URL=https://your-likefb-smm-api.example.com
DATABASE_URL=postgresql://postgres.lradbeedbkzkxsrzkkwx:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
PASSWORD_PEPPER=optional_extra_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# Panel API (serverless routes under /api/smm/* when LIKEFB_SMM_API_BASE_URL is unset)
SMM_API_URL=https://smm.com.vn/api/v2
SMM_API_KEY=your_smm_api_key
# SMM_COOKIE=PHPSESSID=your_session_here
# Optional: json | form | urlencoded — json if panel requires JSON. If unset, a "Request Not Found" on form POST is auto-retried once as JSON.
# SMM_API_BODY_FORMAT=json
# SMM_API_KEY_FIELD=api_key
VITE_MOMO_NAME=Nguyễn Quốc Cường
# Deeplink mở app MoMo (nút "Mở app MoMo" trong modal nạp tiền). Mặc định momo:// nếu bỏ trống.
# VITE_MOMO_APP_URL=momo://
VITE_MOMO_QR_IMAGE_URL=/momo-qr.png
VITE_MOMO_NOTE_PREFIX=Noidung
VITE_TELEGRAM_SUPPORT_USERNAME=your_admin_username
VITE_TELEGRAM_SUPPORT_URL=https://t.me/your_group_or_username
VITE_ZALO_SUPPORT_URL=https://zalo.me/your_zalo_id_or_phone